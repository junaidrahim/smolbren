  "keyFeatures": [
    "Ontology-first indexing: frontmatter `type` keys become graph node labels",
    "Wikilink edges: frontmatter keys containing [[wikilinks]] become typed graph edges",
    "BM25 full-text search with optional type filter",
    "Cypher query language over the knowledge graph",
    "Incremental indexing using mtime/size pre-filter and blake3 content hashes",
    "Machine-readable JSON stdout and structured exit codes — designed for agents and scripts",
    "Fully local storage using Lance columnar format — no server required",
    "Works with any Markdown vault, first-class Obsidian support"
  ],
  "publicApiSurface": [
    "smolbren vault add <name> <path> [--default]",
    "smolbren vault list",
    "smolbren vault remove <name>",
    "smolbren index [--full] [--vault <name>]",
    "smolbren search <query> [--type <type>] [--limit <n>]",
    "smolbren query <cypher> [--param key=value ...]",
    "smolbren get <id> [--body]",
    "smolbren links <id> [--type <type>]",
    "smolbren backlinks <id> [--type <type>]",
    "smolbren types",
    "smolbren edges",
    "~/.smolbren/config.json",
    "SMOLBREN_* environment variables"
  ]
